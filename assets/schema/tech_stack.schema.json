{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xfengyin/xfengyin/schema/tech_stack.schema.json",
  "title": "tech_stack.yml",
  "type": "object",
  "required": ["tech_stack"],
  "properties": {
    "tech_stack": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "category", "badge", "alt"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "category": {
            "type": "string",
            "enum": ["backend", "frontend", "tooling"]
          },
          "badge": {
            "type": "string",
            "description": "shields.io URL 或本地 SVG 路径"
          },
          "alt": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  }
}
